{
  "expo": {
    "name": "Allsale: Indian Bazaar",
    "slug": "allsale-shop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/allsale-icon-store.png",
    "scheme": "allsale",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Shop authentic Indian fashion, beauty, home and food — sent straight from verified sellers in India to your door in New Zealand, Australia, the UK, USA and Canada.",
    "primaryColor": "#F37021",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.allsale.shop",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload product photos to your listings",
        "NSPhotoLibraryAddUsageDescription": "Save product images shared in chat",
        "NSCameraUsageDescription": "Take photos of products or receipts",
        "NSMicrophoneUsageDescription": "Record short videos for product listings",
        "NSLocationWhenInUseUsageDescription": "Show nearby sellers and accurate delivery times",
        "NSContactsUsageDescription": "Invite friends to shop with you",
        "NSUserTrackingUsageDescription": "Personalise your home feed and deal recommendations",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.allsale.shop",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/allsale-logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/allsale-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload product photos to your listings",
          "cameraPermission": "Take photos of products or receipts"
        }
      ],
      "expo-video",
      "expo-localization",
      "expo-apple-authentication",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportEmail": "support@allsale.co.nz",
      "privacyPolicyUrl": "https://shop.allsale.co.nz/legal/privacy",
      "termsUrl": "https://shop.allsale.co.nz/legal/terms"
    }
  }
}
