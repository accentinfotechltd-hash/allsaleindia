{
  "expo": {
    "name": "Allsale: Indian Bazaar",
    "slug": "allsale-shop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/allsale-logo.png",
    "scheme": "allsale",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.allsale.shop",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload product photos to your seller listings",
        "NSCameraUsageDescription": "Take photos of your products to sell on Allsale"
      }
    },
    "android": {
      "package": "com.allsale.shop",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/allsale-logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/allsale-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload product photos to your seller listings",
          "cameraPermission": "Take photos of your products to sell on Allsale"
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

